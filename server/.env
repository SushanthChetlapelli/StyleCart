# Must match what you open in MongoDB Compass, or Compass will show a different (empty) cluster.
# Local: docker compose up -d  →  Compass URI: mongodb://127.0.0.1:27017  →  database: stylecart  →  collection: users
# Atlas: set mongodb+srv://.../stylecart (or your DB name) here AND connect Compass to that same cluster/DB.
MONGODB_URI=mongodb://127.0.0.1:27017/stylecart
JWT_SECRET=your_jwt_secret_key_here_change_in_production_23456789
