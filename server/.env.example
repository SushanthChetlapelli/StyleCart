# Use the SAME URI in MongoDB Compass as here — otherwise signup/login data will not appear where you look.
#
# Local (docker compose up -d from project root):
# MONGODB_URI=mongodb://127.0.0.1:27017/stylecart
# Compass: mongodb://127.0.0.1:27017 → database "stylecart" → collection "users"
#
# Atlas (cloud):
MONGODB_URI=mongodb+srv://StyleCart:<db_password>@stylecart.xdscufn.mongodb.net/stylecart?appName=StyleCart
JWT_SECRET=your_jwt_secret_key_here_change_in_production
PORT=5000
FRONTEND_URL=http://localhost:8080
